# LTDJ management system - Environment Configuration
# Copy this file to .env and fill in your values.
# Environment variables take precedence over .env values.

# ============================================================
# Discord Bot Configuration (Required)
# ============================================================

# Your Discord bot token from the Discord Developer Portal
# https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# ============================================================
# Database Configuration
# ============================================================

# PostgreSQL connection URL
# Format: jdbc:postgresql://host:port/database
DB_URL=jdbc:postgresql://localhost:5432/currency_bot

# Database credentials
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ============================================================
# Connection Pool Configuration (Optional)
# ============================================================

# Maximum number of connections in the pool (default: 10)
DB_POOL_MAX_SIZE=10

# Minimum number of idle connections (default: 2)
DB_POOL_MIN_IDLE=2

# Connection timeout in milliseconds (default: 30000)
DB_POOL_CONNECTION_TIMEOUT=30000

# Idle connection timeout in milliseconds (default: 600000)
DB_POOL_IDLE_TIMEOUT=600000

# Maximum connection lifetime in milliseconds (default: 1800000)
DB_POOL_MAX_LIFETIME=1800000

# ============================================================
# AI Service Configuration
# ============================================================

# AI service base URL (default: https://api.openai.com/v1)
# For OpenAI: https://api.openai.com/v1
# For Azure OpenAI: https://your-resource.openai.azure.com/openai/deployments/your-deployment
# For DeepSeek: https://api.deepseek.com/v1
# For local Ollama: http://localhost:11434/v1
AI_SERVICE_BASE_URL=https://api.openai.com/v1

# AI service API key (required)
# Get your API key from your AI service provider
AI_SERVICE_API_KEY=your_ai_service_api_key_here

# AI model name (default: gpt-4o-mini)
# Examples: gpt-3.5-turbo, gpt-4, gpt-4o-mini, gpt-4o, deepseek-reasoner, etc.
AI_SERVICE_MODEL=gpt-4o-mini

# Temperature for AI response generation (0.0-2.0, default: 0.7)
# Lower values (0.0-0.3) = more focused and deterministic
# Higher values (0.7-2.0) = more creative and random
AI_SERVICE_TEMPERATURE=0.7

# 連線逾時秒數（1-120，預設：30）
# 僅限制建立連線時間，不限制 AI 推理耗時
AI_SERVICE_TIMEOUT_SECONDS=30

# Log AI requests (true/false, default: false)
# Set to true for debugging AI API calls
AI_LOG_REQUESTS=false

# Log AI responses (true/false, default: false)
# Set to true for debugging AI API responses
AI_LOG_RESPONSES=false

# Maximum retry attempts for AI API calls (default: 2)
AI_MAX_RETRIES=2

# AI 推理內容顯示開關（true/false，預設：false）
# 設為 true 時，會在 Discord 顯示 AI 的推理內容（以小字體呈現）
AI_SHOW_REASONING=false
