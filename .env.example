# LTDJ management system - Environment Configuration
# Copy this file to .env and fill in your values.
# Environment variables take precedence over .env values.

# ============================================================
# Discord Bot Configuration (Required)
# ============================================================

# Your Discord bot token from the Discord Developer Portal
# https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# ============================================================
# Database Configuration
# ============================================================

# PostgreSQL connection settings
# 建議使用下列 DATABASE_* 變數（Docker 內 host 建議用 postgres）
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=currency_bot

# 若一定要使用 JDBC URL，可改用 DB_URL；但有設定 DB_URL 時會覆蓋 DATABASE_*。
# DB_URL=jdbc:postgresql://localhost:5432/currency_bot

# Database credentials
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ============================================================
# Connection Pool Configuration (Optional)
# ============================================================

# Maximum number of connections in the pool (default: 10)
DB_POOL_MAX_SIZE=10

# Minimum number of idle connections (default: 2)
DB_POOL_MIN_IDLE=2

# Connection timeout in milliseconds (default: 30000)
DB_POOL_CONNECTION_TIMEOUT=30000

# Idle connection timeout in milliseconds (default: 600000)
DB_POOL_IDLE_TIMEOUT=600000

# Maximum connection lifetime in milliseconds (default: 1800000)
DB_POOL_MAX_LIFETIME=1800000

# ============================================================
# Logging Configuration (Optional)
# ============================================================

# Root logger level: TRACE, DEBUG, INFO, WARN, ERROR (default: WARN)
LOG_LEVEL=WARN

# Application logger level for ltdjms.discord.* (default: INFO)
APP_LOG_LEVEL=INFO

# Log directory path (default: logs, Docker default: /app/logs)
LOG_DIR=logs

# Max size per rolled log file (default: 20MB)
LOG_MAX_FILE_SIZE=20MB

# Number of days to keep rolled logs (default: 30)
LOG_MAX_HISTORY_DAYS=30

# Total disk cap of rolled logs (default: 3GB)
LOG_TOTAL_SIZE_CAP=3GB

# ============================================================
# Cache (Redis) Configuration
# ============================================================

# Redis connection URI (default: redis://localhost:6379)
REDIS_URI=redis://localhost:6379

# ============================================================
# ECPay Payment Configuration
# ============================================================

# 綠界商店代號（測試環境可使用 3002607）
ECPAY_MERCHANT_ID=

# 綠界 HashKey（測試環境可使用 pwFHCqoQZGmho4w6）
ECPAY_HASH_KEY=

# 綠界 HashIV（測試環境可使用 EkRm7iFT261dpevs）
ECPAY_HASH_IV=

# Compose 自架 Caddy ingress 使用的公開網域（必填）
# 例如：pay.example.com
APP_PUBLIC_DOMAIN=

# Caddy automatic HTTPS 使用的 ACME 聯絡 email（必填）
# 憑證簽發/續期失敗時，Let's Encrypt 會使用此信箱聯絡。
CADDY_ACME_EMAIL=

# 自架部署的公開 base URL。
# 若使用 repo 內的 Caddy ingress，通常應設為 `https://<APP_PUBLIC_DOMAIN>`。
# 可直接填裸網域 `pay.example.com`，系統會自動補成 `https://pay.example.com`；
# 也可填完整 URL，例如 `https://pay.example.com` 或 `https://example.com/store`。
# 若未另外設定 ECPAY_RETURN_URL，系統會自動推導為 APP_PUBLIC_BASE_URL + ECPAY_CALLBACK_PATH。
APP_PUBLIC_BASE_URL=

# 綠界付款結果通知網址（ReturnURL，進階 override）。
# 一般情況建議留空，讓系統從 APP_PUBLIC_BASE_URL 自動推導。
# 只有當 callback URL 必須和公開 base URL 不同時，再手動指定完整網址。
ECPAY_RETURN_URL=

# 是否使用綠界測試環境（預設：true）
ECPAY_STAGE_MODE=true

# 超商代碼繳費期限（分鐘，1-10080，預設：10080）
ECPAY_CVS_EXPIRE_MINUTES=10080

# 綠界付款回推監聽綁定 Host（預設：127.0.0.1）
# Compose 自架 ingress 預設會由 repo 內 Caddy 代理到這個 loopback 入口，通常不需要手動修改。
# 若你不是使用 repo 內 Compose ingress，才需要把它視為進階 override。
ECPAY_CALLBACK_BIND_HOST=127.0.0.1

# 綠界付款回推監聽綁定 Port（預設：8085）
# Compose 自架 ingress 預設會代理到這個內部 port，通常不需要手動修改。
ECPAY_CALLBACK_BIND_PORT=8085

# 綠界付款回推路徑（預設：/ecpay/callback）
# ECPay ReturnURL 請設為公開網域加上這個路徑，例如 https://example.com/ecpay/callback
ECPAY_CALLBACK_PATH=/ecpay/callback

# 綠界付款回推共享密鑰（舊版 query token 相容欄位；現行 callback 流程不再使用）
ECPAY_CALLBACK_SHARED_SECRET=

# 商品履約 webhook HMAC 簽章密鑰（啟用商品履約時必填）
PRODUCT_FULFILLMENT_SIGNING_SECRET=

# ============================================================
# AI Service Configuration
# ============================================================

# AI service base URL (default: https://api.openai.com/v1)
# For OpenAI: https://api.openai.com/v1
# For Azure OpenAI: https://your-resource.openai.azure.com/openai/deployments/your-deployment
# For DeepSeek: https://api.deepseek.com/v1
# For local Ollama: http://localhost:11434/v1
AI_SERVICE_BASE_URL=https://api.openai.com/v1

# AI service API key (required)
# Get your API key from your AI service provider
AI_SERVICE_API_KEY=your_ai_service_api_key_here

# AI model name (default: gpt-4o-mini)
# Examples: gpt-3.5-turbo, gpt-4, gpt-4o-mini, gpt-4o, deepseek-reasoner, etc.
AI_SERVICE_MODEL=gpt-4o-mini

# Temperature for AI response generation (0.0-2.0, default: 0.7)
# Lower values (0.0-0.3) = more focused and deterministic
# Higher values (0.7-2.0) = more creative and random
AI_SERVICE_TEMPERATURE=0.7

# 連線逾時秒數（1-120，預設：30）
# 僅限制建立連線時間，不限制 AI 推理耗時
AI_SERVICE_TIMEOUT_SECONDS=30

# AI 推理內容顯示開關（true/false，預設：false）
# 設為 true 時，會在 Discord 顯示 AI 的推理內容（以小字體呈現）
AI_SHOW_REASONING=false

# ============================================================
# Prompt Loader Configuration
# ============================================================

# 提示詞資料夾路徑（相對或絕對，預設：./prompts）
PROMPTS_DIR_PATH=./prompts

# 單一提示詞檔案大小上限（bytes，預設：1048576，即 1MB）
PROMPT_MAX_SIZE_BYTES=1048576

# ============================================================
# Markdown Validation Configuration
# ============================================================

# 是否啟用 Markdown 驗證（預設：true）
AI_MARKDOWN_VALIDATION_ENABLED=true

# 串流模式是否繞過驗證（預設：false，建議僅在需要即時逐 token 輸出時啟用）
AI_MARKDOWN_VALIDATION_STREAMING_BYPASS=false
